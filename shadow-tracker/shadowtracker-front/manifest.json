{
  "manifest_version": 3,
  "name": "Shadow Checker",
  "version": "1.0",
  "description": "Auditoria de preços com IA de Visão.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Checar Preço Sombra",
    "default_icon": "icon16.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}